# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# 虚拟环境
venv/
env/
.venv/
ENV/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# 本地持久化数据（向量数据库）
chroma_db/

# 忽略 Gradio 缓存
.gradio/

# 记忆和状态文件（如果启用持久化）
memory.json
state.json

# 配置文件（包含本地路径或敏感信息）
.env

# 日志文件
*.log

# 其他临时文件
*.tmp
*.bak
*.orig

# 忽略实际配置文件
config.ini
config.json
# 忽略敏感信息
*.key
*.secret
